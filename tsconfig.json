{
  "compilerOptions": {
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2020",
    "allowJs": false,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": [
      "DOM",
      "ES2020"
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "main.ts"
  ]
}
