{
	"name": "obsidian-markdown-dialect-ial",
	"version": "1.0.0",
	"description": "Obsidian Markdown Dialect – IAL: Pandoc-style Inline Attribute Lists for Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint src",
		"test": "jest",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"markdown",
		"ial",
		"inline-attribute-list",
		"pandoc"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/jest": "^29.5.14",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"obsidian": "latest",
		"ts-jest": "^29.3.4",
		"typescript": "^5.8.3"
	}
}
