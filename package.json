{
  "name": "markdown-dialect-ial",
  "version": "1.0.1",
  "description": "Obsidian plugin development environment for Markdown Dialect IAL.",
  "main": "main.js",
  "scripts": {
    "build": "tsc --noEmit && node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "lint": "eslint main.ts --max-warnings=0",
    "lint:fix": "eslint main.ts --fix --max-warnings=0",
    "version:patch": "node scripts/bump-patch-version.mjs",
    "version:minor": "node scripts/bump-minor-version.mjs",
    "version:major": "node scripts/bump-major-version.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "markdown",
    "ial"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.23.1",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "1.13.1",
    "tslib": "^2.7.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6"
  }
}
